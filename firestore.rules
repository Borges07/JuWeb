rules_version = '2';

// Regras de segurança do Firestore para a votação.
//
// Identidades:
//   Visitante (não logado): LÊ jogadores/categorias/configurações.
//   Votante (login Google):  cria 1 voto (doc id = uid). Não é admin.
//   Admin (allowlist):       controle total; é o único que LÊ os votos.
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin = usuário autenticado cujo uid está na coleção `admins`.
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Allowlist de administradores (doc id = uid). Gerenciada só pelo Console.
    // Cada usuário pode checar apenas o próprio doc (para a tela saber se é admin).
    match /admins/{uid} {
      allow get: if request.auth != null && request.auth.uid == uid;
      allow list, write: if false;
    }

    // Jogadores: leitura pública; escrita apenas admin.
    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Votos: 1 por conta (doc id = uid).
    //   - get do próprio voto: o dono (para saber se já votou) ou admin.
    //   - list (apurar resultados): apenas admin.
    //   - create: precisa estar logado e o id do doc tem que ser o uid.
    //   - update/delete: apenas admin.
    match /votes/{voteId} {
      allow get: if isAdmin() || (request.auth != null && request.auth.uid == voteId);
      allow list: if isAdmin();
      allow create: if request.auth != null
                    && request.auth.uid == voteId
                    && request.resource.data.playerId is string;
      allow update, delete: if isAdmin();
    }

    // Configurações da votação: leitura pública; escrita apenas admin.
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categorias: leitura pública (alimenta o filtro/seleção); escrita apenas admin.
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
