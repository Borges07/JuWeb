rules_version = '2';

// Regras de segurança do Firestore para a votação.
//
// Resumo (conforme especificação):
//   Usuário comum (não autenticado): pode LER jogadores e CRIAR voto.
//   Usuário comum NÃO pode: alterar/excluir votos, nem alterar jogadores.
//   Administrador (autenticado): controle total.
service cloud.firestore {
  match /databases/{database}/documents {

    // Qualquer pessoa autenticada é tratada como administrador.
    // (Para restringir a admins específicos, troque por uma checagem de
    //  custom claims, ex.: request.auth.token.admin == true.)
    function isAdmin() {
      return request.auth != null;
    }

    // Jogadores: leitura pública; escrita apenas admin.
    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Votos: leitura pública (para apurar resultados); criação pública,
    // porém sem permitir alteração/exclusão por usuário comum.
    match /votes/{voteId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['playerId', 'fingerprint', 'createdAt'])
                    && request.resource.data.playerId is string
                    && request.resource.data.fingerprint is string;
      allow update, delete: if isAdmin();
    }

    // Configurações da votação: leitura pública; escrita apenas admin.
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categorias: leitura pública (alimenta o filtro/seleção); escrita apenas admin.
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
